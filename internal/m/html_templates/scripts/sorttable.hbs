<script>

    function fixTable() {
        let target = document.querySelector('.target'),
            source = document.querySelector('.source');

        function strip(str) {
            return new DOMParser().parseFromString(str, 'text/html').body.textContent || '';
        }

        function sort(a, b) {
            a = strip(a),
            b = strip(b);
            if (a > b) {
                return 1;
            } else if (b > a) {
                return -1;
            } else {
                return 0;
            }
        }

        function sortDates(a, b) {
            // Dates are formatted as Apr 4, 2021
            a = new Date(strip(a)).getTime()
            b = new Date(strip(b)).getTime()

            if (a > b) {
                return 1;
            } else if (b > a) {
                return -1;
            } else {
                return 0;
            }

        }

        function sortNumbers(a, b) {
            a = parseFloat(strip(a)) || 0;
            b = parseFloat(strip(b)) || 0;
            return a - b;
        }

        new gridjs.Grid({
            sort: true,
            {{#if search }}
            search: true,
            {{/if}}
            columns: Array.from(source.querySelectorAll('thead th')).map(th => {
                const dataType = th.getAttribute("dataType");
                let compareFunc = sort;
                if (dataType === "date") {
                    compareFunc = sortDates;
                } else if (dataType === "number") {
                    compareFunc = sortNumbers;
                }
                return {
                    name: th.textContent,
                    formatter: (cell) => gridjs.html(cell),
                    sort: {
                        compare: compareFunc
                    }
                };
            }),
            data: Array.from(source.querySelectorAll('tbody tr')).map(tr => Array.from(tr.querySelectorAll('td')).map(td => td.innerHTML)),
        }).render(target);

        // Set source to be display none
        source.style.display = 'none';
    }

    if (typeof(gridjs) !== 'undefined') {
        console.log("GridJS is loaded");
        fixTable();
    } else {
        setTimeout(fixTable, 1000);
    }
</script>