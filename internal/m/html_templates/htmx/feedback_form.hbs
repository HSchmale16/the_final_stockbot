<div id="feedback-form" class="p-4">
    <form hx-post="/feedback" hx-target="#feedback-form" hx-swap="outerHTML" class="flex flex-col space-y-4">
        <span id="warning" class="text-red-400 text-sm"></span>

        <label for="name" class="text-gray-200 text-sm font-medium">Your name:</label>
        <input required type="text" id="name" name="name" placeholder="Your name"
            class="p-2 border border-gray-500 rounded-md bg-gray-700 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400">

        <label for="email" class="text-gray-200 text-sm font-medium">Your email (if you want us to reach out):</label>
        <input type="email" id="email" name="email" placeholder="Your email"
            class="p-2 border border-gray-500 rounded-md bg-gray-700 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400">

        <label for="message" class="text-gray-200 text-sm font-medium">Your message:</label>
        <textarea required id="message" name="message" placeholder="Your message"
            class="p-2 border border-gray-500 rounded-md bg-gray-700 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-400 min-h-24"></textarea>

        <input name="url" hidden="true" value="{{ Url }}" />

        <button class="btn">Send</button>
    </form>
</div>